# Copy to apps/web/.env.local and fill in. NEVER commit .env.local.
# Phase 11 — env vars consumed by the Next.js runtime + build.

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:55432/googenie

# ─── Clerk ──────────────────────────────────────────────────────────────────
# `NEXT_PUBLIC_*` is exposed to the browser bundle; everything else is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ─── HMAC tokens (legacy + demo) ────────────────────────────────────────────
# 64-char hex: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NIMBUS_ACCESS_TOKEN_SECRET=
NIMBUS_REFRESH_TOKEN_SECRET=

# ─── Google OAuth (Corsair) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Phase 8 step 44 — must be /api/v1/me/connect/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/me/connect/callback
CORSAIR_KEK=replace-with-32-hex-chars-minimum-length

# ─── AI (optional, graceful degradation) ────────────────────────────────────
MISTRAL_API_KEY=

# ─── Public URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# ─── Demo tokens (optional — populate via scripts/gen-demo-tokens.ts) ───────
DEMO_TOKEN_SUPER_ADMIN=
DEMO_TOKEN_HITESH=
DEMO_TOKEN_PIYUSH=
DEMO_TOKEN_USER=

# ─── Misc ───────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=dev-admin
PORT=3000
NODE_ENV=development
