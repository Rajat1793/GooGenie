{
  "name": "googenie-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "pnpm --filter @googenie/web dev",
    "build": "pnpm --filter @googenie/web build",
    "typecheck": "pnpm --filter @googenie/web typecheck",
    "dev:web": "pnpm --filter @googenie/web dev",
    "build:web": "pnpm --filter @googenie/web build",
    "typecheck:web": "pnpm --filter @googenie/web typecheck"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0"
    }
  }
}
