{
  "name": "googenie-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:render": "pnpm install --frozen-lockfile --prod=false && tsc -p tsconfig.json && pnpm run db:migrate",
    "build:prod": "tsc -p tsconfig.json && node dist/scripts/seed-admin.js || true",
    "start": "node dist/src/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:deps": "pnpm audit --audit-level high",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "perf:baseline": "tsx scripts/perf-baseline.ts",
    "uat:signoff": "tsx scripts/uat-signoff.ts",
    "launch:readiness": "tsx scripts/launch-readiness.ts",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "corsair": "^0.1.76",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "pg": "^8.13.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@corsair-dev/cli": "^0.1.19",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.12.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.2"
  }
}
